{
  "name": "4h-cat-voting",
  "version": "0.1.0",
  "description": "4H Cat Voting Application with CDK Infrastructure",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "web:test": "react-scripts test",
    "cdk:test": "jest",
    "cdk": "cdk",
    "deploy": "cdk deploy",
    "destroy": "cdk destroy",
    "synth": "cdk synth",
    "bootstrap": "cdk bootstrap",
    "test:integration": "node src/__tests__/run-integration-tests.js",
    "test:integration:fitshow": "npm test -- --testNamePattern=\"fit.*show.*integration\" --watchAll=false",
    "test:fitshow:frontend": "npm test -- --testPathPattern=\"fit-show.*test.tsx\" --watchAll=false",
    "test:fitshow:backend": "cd infrastructure && npm test -- --testPathPattern=\"fitShow.*test.ts\" --watchAll=false",
    "test:fitshow:all": "npm run test:fitshow:frontend && npm run test:fitshow:backend"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/aws-lambda": "^8.10.0",
    "@types/jest": "^29.4.0",
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "aws-cdk": "^2.1021.0",
    "jest": "^29.5.0",
    "jest-axe": "^10.0.0",
    "ts-jest": "^29.0.5",
    "ts-node": "^10.9.1",
    "typescript": "~5.3.0"
  },
  "dependencies": {
    "@aws-amplify/ui-react": "^6.0.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.844.0",
    "@aws-sdk/client-dynamodb": "^3.844.0",
    "@aws-sdk/client-lambda": "^3.844.0",
    "@aws-sdk/lib-dynamodb": "^3.844.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.1",
    "@mui/material": "^7.3.1",
    "@types/node-fetch": "^2.6.11",
    "aws-amplify": "^6.0.0",
    "aws-cdk-lib": "^2.206.0",
    "aws-lambda": "^1.0.7",
    "constructs": "^10.0.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "node-fetch": "^2.7.0",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.0",
    "react-scripts": "5.0.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
