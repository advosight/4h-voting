{
  "name": "4h-cat-voting",
  "version": "0.1.0",
  "description": "4H Cat Voting Application with CDK Infrastructure",
  "scripts": {
    "start": "cross-env NODE_OPTIONS=--localstorage-file=/tmp/4h-voting-jest-localstorage.db vite",
    "build": "cross-env NODE_OPTIONS=--localstorage-file=/tmp/4h-voting-jest-localstorage.db vite build",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "test": "cross-env NODE_OPTIONS=--localstorage-file=/tmp/4h-voting-jest-localstorage.db vitest run",
    "web:test": "npm run test",
    "cdk": "cdk",
    "deploy": "cdk deploy",
    "deploy:production": "cdk deploy -c stage=production",
    "destroy": "cdk destroy",
    "synth": "cdk synth",
    "bootstrap": "cdk bootstrap",
    "test:web": "npm run web:test",
    "test:integration": "node src/scripts/run-integration-tests.js",
    "test:integration:fitshow": "npm run test -- --testNamePattern=\"fit.*show.*integration\"",
    "test:fitshow:frontend": "npm run test -- fit-show",
    "test:fitshow:backend": "cd infrastructure && npm test -- --testPathPattern=\"fitShow.*test.ts\" --watchAll=false",
    "test:fitshow:all": "npm run test:fitshow:frontend && npm run test:fitshow:backend"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "^26.1.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "aws-cdk": "^2.1129.0",
    "cross-env": "^10.1.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.1",
    "ts-node": "^10.9.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@aws-amplify/ui-react": "^6.15.4",
    "@aws-sdk/client-cognito-identity-provider": "^3.1084.0",
    "@aws-sdk/client-dynamodb": "^3.1084.0",
    "@aws-sdk/client-lambda": "^3.1084.0",
    "@aws-sdk/lib-dynamodb": "^3.1084.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "aws-amplify": "^6.18.0",
    "aws-cdk-lib": "^2.261.0",
    "aws-lambda": "^1.0.7",
    "constructs": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
