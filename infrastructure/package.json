{
  "name": "4h-cat-voting-infrastructure",
  "version": "0.1.0",
  "bin": {
    "infrastructure": "bin/infrastructure.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "test:integration": "jest --testPathPattern=\"integration.test\"",
    "test:scoring": "jest --testPathPattern=\"(scoring|score)\"",
    "test:coverage": "jest --testPathPattern=\"(scoring|score)\" --coverage",
    "cdk": "cdk",
    "deploy": "cdk deploy",
    "destroy": "cdk destroy",
    "migrate:fitshow": "node scripts/migrate-fit-show-scoring.js",
    "migrate:fitshow:sample": "node scripts/migrate-fit-show-scoring.js --create-sample"
  },
  "devDependencies": {
    "@types/jest": "^29.4.0",
    "@types/node": "^20.0.0",
    "aws-cdk": "^2.1021.0",
    "aws-sdk-client-mock": "^4.0.1",
    "jest": "^29.5.0",
    "ts-jest": "^29.0.5",
    "ts-node": "^10.9.1",
    "typescript": "~5.3.0"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.844.0",
    "@aws-sdk/client-dynamodb": "^3.844.0",
    "@aws-sdk/client-lambda": "^3.844.0",
    "@aws-sdk/lib-dynamodb": "^3.844.0",
    "@types/node-fetch": "^2.6.11",
    "aws-cdk-lib": "^2.206.0",
    "aws-lambda": "^1.0.7",
    "constructs": "^10.0.0",
    "node-fetch": "^2.7.0"
  }
}
