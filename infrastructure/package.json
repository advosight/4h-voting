{
  "name": "4h-cat-voting-infrastructure",
  "version": "0.1.0",
  "bin": {
    "infrastructure": "bin/infrastructure.js"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "watch": "tsc -w",
    "pretest": "cd .. && npm run build",
    "test": "cross-env NODE_OPTIONS=--localstorage-file=/tmp/4h-voting-jest-localstorage.db jest",
    "test:integration": "cross-env NODE_OPTIONS=--localstorage-file=/tmp/4h-voting-jest-localstorage.db jest --testPathPattern=\"integration.test\"",
    "test:scoring": "cross-env NODE_OPTIONS=--localstorage-file=/tmp/4h-voting-jest-localstorage.db jest --testPathPattern=\"(scoring|score)\"",
    "test:coverage": "cross-env NODE_OPTIONS=--localstorage-file=/tmp/4h-voting-jest-localstorage.db jest --testPathPattern=\"(scoring|score)\" --coverage",
    "cdk": "cdk",
    "deploy": "cdk deploy",
    "destroy": "cdk destroy",
    "migrate:fitshow": "node scripts/migrate-fit-show-scoring.js",
    "migrate:fitshow:sample": "node scripts/migrate-fit-show-scoring.js --create-sample",
    "backfill:daily-votes": "node scripts/backfill-daily-votes.js",
    "backfill:daily-votes:apply": "node scripts/backfill-daily-votes.js --apply"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "aws-cdk": "^2.1130.0",
    "aws-sdk-client-mock": "^4.1.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1084.0",
    "@aws-sdk/client-dynamodb": "^3.1084.0",
    "@aws-sdk/client-lambda": "^3.1084.0",
    "@aws-sdk/lib-dynamodb": "^3.1084.0",
    "aws-cdk-lib": "^2.261.0",
    "aws-lambda": "^1.0.7",
    "constructs": "^10.6.0"
  }
}
