VITE_USER_POOL_ID=your_user_pool_id
VITE_USER_POOL_CLIENT_ID=your_user_pool_client_id
VITE_GRAPHQL_ENDPOINT=your_appsync_endpoint
VITE_REGION=us-east-1
VITE_VOTING_API_ENDPOINT=The_voting_endpoint_from_cloudfront
# From the GraphQLApiKey CDK output; lets the unauthenticated accept-invite
# page call validateInvitation before the user has a Cognito session.
VITE_GRAPHQL_API_KEY=your_appsync_api_key

# CDK deploy-time only (read by infrastructure/bin/infrastructure.ts, not by Vite).
# Verified SES sender identity used to send invite emails.
SES_FROM_EMAIL=noreply@advosight.com
